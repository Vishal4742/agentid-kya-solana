# =============================================================================
# AgentID Oracle Environment
# Copy this file to .env and fill every REPLACE_WITH_* value before running.
# =============================================================================
#
# Quick start
#   1. cp .env.example .env
#   2. Fill the values below
#   3. Run `npm run dev`
#   4. Expose port 3001 with ngrok or deploy the service
#   5. Run `./node_modules/.bin/ts-node src/register-webhook.ts`

# 1. Oracle Authority Private Key
# Use the same keypair whose public key was passed as `oracle_authority`
# when `init_config` was executed on devnet.
#
# How to get it
#   cat ~/.config/solana/id.json
#
# Format
#   JSON array with 64 integers, e.g. [12,34,...,255]
ORACLE_PRIVATE_KEY=[REPLACE_WITH_ORACLE_AUTHORITY_KEYPAIR_ARRAY]

# 2. Solana RPC URL
# Helius devnet RPC is recommended for webhook-driven indexing.
#
# How to get it
#   1. Sign in at https://dev.helius.xyz/
#   2. Create or open a devnet project
#   3. Copy the RPC URL
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=REPLACE_WITH_HELIUS_API_KEY

# 3. Helius API Key
# Required by src/register-webhook.ts.
# This is the raw API key portion from your Helius dashboard.
HELIUS_API_KEY=REPLACE_WITH_HELIUS_API_KEY

# 4. Webhook Authentication Secret
# The oracle expects every webhook request to include this exact value in
# the Authorization header.
#
# Generate one
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HELIUS_WEBHOOK_AUTH=replace-with-a-long-random-secret

# 5. Public Webhook URL
# This is the public URL Helius should post to.
#
# Local dev with ngrok
#   1. ngrok http 3001
#   2. Copy the forwarding URL
#   3. Set WEBHOOK_URL=https://<ngrok-id>.ngrok-free.app/webhook
WEBHOOK_URL=https://REPLACE_WITH_PUBLIC_WEBHOOK_URL/webhook

# 6. Oracle Port
PORT=3001

# =============================================================================
# Local setup steps
# =============================================================================
#
# 1. Install dependencies
#   cd backend/oracle
#   npm install
#
# 2. Create .env
#   cp .env.example .env
#
# 3. Fill the required values
#   ORACLE_PRIVATE_KEY=...
#   SOLANA_RPC_URL=...
#   HELIUS_API_KEY=...
#   HELIUS_WEBHOOK_AUTH=...
#   WEBHOOK_URL=https://<your-ngrok-id>.ngrok-free.app/webhook
#
# 4. Start the oracle
#   npm run dev
#
# 5. Register the webhook
#   ./node_modules/.bin/ts-node src/register-webhook.ts
#
# 6. Verify init_config on devnet
#   ProgramConfig PDA:
#   HdtBWtW3smBmdjrZd5T5pJCF7e5XAdRxhHQu8KVmfQfk
#
# Troubleshooting
#   - POST /webhook returns 500 when HELIUS_WEBHOOK_AUTH is missing in .env
#   - register-webhook.ts exits when HELIUS_API_KEY, WEBHOOK_URL, or
#     HELIUS_WEBHOOK_AUTH are missing
