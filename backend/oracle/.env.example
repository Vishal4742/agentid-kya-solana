# =============================================================================
# AgentID Oracle — Environment Variables
# Copy this file to .env and fill in every value before running the oracle.
# Never commit .env to git — it is in .gitignore.
# =============================================================================

# ── 1. Oracle Authority Private Key ──────────────────────────────────────────
#
# The keypair whose public key was passed as `oracle_authority` in init_config.
# Currently set to: 9ziKFvAU74jNa8RxnDZRxf2AGoDtCafpzvLXYZP5a1MX (devnet)
#
# HOW TO EXPORT:
#   If you used the Solana CLI default keypair:
#     cat ~/.config/solana/id.json
#   Copy the entire JSON array output here.
#
# FORMAT: A JSON array of 64 integers, e.g. [12,34,56,...,255]
#
ORACLE_PRIVATE_KEY=[REPLACE_WITH_64_BYTE_KEYPAIR_ARRAY]

# ── 2. Solana RPC URL ─────────────────────────────────────────────────────────
#
# Use a Helius devnet RPC for best webhook reliability.
# HOW TO GET:
#   1. Sign up at https://dev.helius.xyz/
#   2. Create a new project → copy the Devnet RPC URL
#   Format: https://devnet.helius-rpc.com/?api-key=YOUR_KEY
#
# Fallback (no sign-up needed, rate-limited):
#   SOLANA_RPC_URL=https://api.devnet.solana.com
#
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=REPLACE_WITH_HELIUS_API_KEY

# ── 3. Helius API Key ─────────────────────────────────────────────────────────
#
# Used by register-webhook.ts to create the webhook via the Helius REST API.
# Same key as in your RPC URL above — just the key portion without the URL.
#
# HOW TO GET:
#   1. Go to https://dev.helius.xyz/ → Dashboard → API Keys
#   2. Copy your Devnet API key
#
HELIUS_API_KEY=REPLACE_WITH_HELIUS_API_KEY

# ── 4. Helius Webhook Auth Header ────────────────────────────────────────────
#
# A shared secret that Helius sends in the Authorization header of every
# webhook request. The oracle validates this header before processing.
#
# HOW TO SET:
#   1. Generate a secure random secret:
#        node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   2. Paste the output here.
#   3. In register-webhook.ts this value is sent as `authHeader` to Helius.
#      Helius will include it in every webhook POST to your server.
#   4. The oracle checks: req.headers.authorization === HELIUS_WEBHOOK_AUTH
#
HELIUS_WEBHOOK_AUTH=REPLACE_WITH_LONG_RANDOM_SECRET

# ── 5. Public Webhook URL ────────────────────────────────────────────────────
#
# The publicly accessible URL where Helius will POST transaction events.
# Used by register-webhook.ts.
#
# FOR LOCAL DEVELOPMENT — use ngrok to expose port 3001:
#   1. Install ngrok: https://ngrok.com/download
#   2. Run: ngrok http 3001
#   3. Copy the Forwarding URL (e.g. https://abc123.ngrok-free.app)
#   4. Set: WEBHOOK_URL=https://abc123.ngrok-free.app/webhook
#
# FOR PRODUCTION — use your deployed service URL:
#   WEBHOOK_URL=https://your-oracle.railway.app/webhook
#
WEBHOOK_URL=https://REPLACE_WITH_NGROK_OR_DEPLOYED_URL/webhook

# ── 6. Oracle Server Port (optional, default: 3001) ──────────────────────────
PORT=3001

# =============================================================================
# SETUP STEPS (run in order after filling all values above)
# =============================================================================
#
# Step 1 — Install dependencies:
#   cd backend/oracle && npm install
#
# Step 2 — Start the oracle server (keep this terminal open):
#   npm run dev
#   Expected output:
#     🔑 Oracle Authority: 9ziKFvAU74jNa8RxnDZRxf2AGoDtCafpzvLXYZP5a1MX
#     📜 Loaded Program: Gv35udP7tnnVcNiCMLKYeyjx1rfkeos4e6cXsFGr4tcF
#     🚀 Oracle backend listening on port 3001
#
# Step 3 — In a separate terminal, start ngrok (for local dev):
#   ngrok http 3001
#   Then update WEBHOOK_URL above with the ngrok URL and restart the oracle.
#
# Step 4 — Register the webhook with Helius (run once):
#   ./node_modules/.bin/ts-node src/register-webhook.ts
#   Expected output:
#     ✅ Successfully registered webhook!
#     Webhook ID: <id>
#
# Step 5 — Verify init_config is applied on devnet:
#   The config PDA HdtBWtW3smBmdjrZd5T5pJCF7e5XAdRxhHQu8KVmfQfk already
#   exists on devnet — no action needed unless you redeploy to a new program ID.
#
# Step 6 — Test webhook locally:
#   curl -X POST http://localhost:3001/webhook \
#     -H "Content-Type: application/json" \
#     -H "Authorization: YOUR_HELIUS_WEBHOOK_AUTH_VALUE" \
#     -d '[{"meta":{"err":null,"logMessages":["Program Gv35... invoke","Instruction: LogAction"]},"signature":"test","accountData":[]}]'
#
# =============================================================================
