# Helius Webhook Setup
# Paste this exact URL into the "Webhook URL" field in your Helius dashboard:
# https://<NGROK_ID>.ngrok-free.dev/webhook

# 1. Oracle Authority Private Key (Array format)
# This MUST be the same wallet keypair array that was used to deploy and initialize the program.
ORACLE_PRIVATE_KEY=[YOUR_AUTHORITY_KEYPAIR_ARRAY]

# 2. Solana RPC URL (Use Helius devnet RPC for best results)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY

# 3. Webhook Authentication Secret
# Set this to a secure random string and provide the same string in the Helius Webhook auth header configuration.
HELIUS_WEBHOOK_AUTH=your_secure_secret_here
