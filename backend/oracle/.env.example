# Oracle sync + webhook setup
# Use these values for:
# - GitHub Actions oracle sync
# - Vercel API webhook route at https://<your-api-domain>/oracle/webhook

# 1. Oracle Authority Private Key (Array format)
# Use a dedicated oracle authority keypair. Never commit the real value.
ORACLE_PRIVATE_KEY=[REPLACE_WITH_ORACLE_AUTHORITY_KEYPAIR_ARRAY]

# 2. Solana RPC URL (Helius devnet RPC recommended)
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=REPLACE_WITH_HELIUS_API_KEY

# 3. Preferred webhook signing secret
# Use this when webhook requests are relayed through a signer that sends:
#   x-agentid-signature: sha256=<hex>
ORACLE_WEBHOOK_SECRET=replace-with-a-long-random-secret

# 4. Optional direct Helius auth header fallback
# Only required if Helius posts directly to the Vercel webhook route with a static Authorization header.
HELIUS_WEBHOOK_AUTH=replace-with-a-long-random-secret

# 5. Helius webhook registration inputs
# Required only when running `npm run register:webhook`.
HELIUS_API_KEY=replace-with-helius-api-key
WEBHOOK_URL=https://your-api-domain.vercel.app/oracle/webhook
